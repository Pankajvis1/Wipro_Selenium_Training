pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                git branch: 'master',
                    url: 'https://github.com/Pankajvis1/Wipro_Selenium_Training.git'
            }
        }

        stage('Docker Build') {
            steps {
                dir('eclipse-workspace/Cucumber_BDD') {
                    sh 'docker build -t cucumber-framework .'
                }
            }
        }

        stage('Docker Run') {
            steps {
                sh 'docker run --rm cucumber-framework'
            }
        }
    }

    post {
        success {
            echo 'Build Successful'
        }

        failure {
            echo 'Build Failed'
        }
    }
}