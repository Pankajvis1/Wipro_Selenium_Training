pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                git branch: 'master',
                    url: 'https://github.com/Pankajvis1/Wipro_Selenium_Training.git'
            }
        }

        stage('Docker Build') {
            steps {
                dir('eclipse-workspace/Cucumber_BDD') {
                    sh 'docker build -t cucumber-framework .'
                }
            }
        }

        stage('Start Selenium Chrome') {
            steps {
                sh 'docker network create selenium-net || true'
                sh 'docker rm -f selenium-chrome || true'

                sh '''
                docker run -d \
                --name selenium-chrome \
                --network selenium-net \
                -p 4444:4444 \
                --platform linux/amd64 \
                selenium/standalone-chrome:latest
                '''

                sh 'sleep 30'
            }
        }

        stage('Run Tests') {
            steps {
                sh '''
                docker run --rm \
                --network selenium-net \
                cucumber-framework \
                mvn test \
                -Dtest=Runner.RunCucumberTest \
                -Dselenium.remote.url=http://selenium-chrome:4444/wd/hub
                '''
            }
        }
    }

    post {

        success {
            echo 'Build Successful'
        }

        failure {
            echo 'Build Failed'
        }

        always {
            sh 'docker rm -f selenium-chrome || true'
        }
    }
}